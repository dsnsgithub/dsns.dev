---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

import chromocraftSeason1 from "../assets/smps/chromocraftseason1.png";
import firstSMP from "../assets/smps/firstsmp.png";
import earth14000Smp from "../assets/smps/earthsmp.png";
import chromocraftSeason2 from "../assets/smps/chromocraftseason2.png";
import chromocraftSeason3 from "../assets/smps/chromocraftseason3.png";
import chromocraftSeason4 from "../assets/smps/chromocraftseason4.png";
import citySmp from "../assets/smps/citysmp.png";
import one17Smp from "../assets/smps/1-17-smp.png";
import one18SnapshotSmp from "../assets/smps/1-18-smp.png";
import mcDsnsDevPart1 from "../assets/smps/mc-dsns-dev-part-1.png";
import mcDsnsDevPart2 from "../assets/smps/mc-dsns-dev-part-2.png";
import deliciousSmp from "../assets/smps/delicious-smp.png";
import aNewBeginningSmp from "../assets/smps/a-new-beginning.png";


const smps = [
	{
		name: "First SMP",
		url: "https://archive.org/details/first-smp",
		image: firstSMP,
		date: "2017-10-06",
		size: "8.7 MB"
	},
	{
		name: "Chromocraft Season 1",
		url: "https://archive.org/details/chromocraft-season-1",
		image: chromocraftSeason1,
		date: "2017-10-18",
		size: "20.5 MB"
	},
	{
		name: "Chromocraft Season 2",
		url: null,
		image: chromocraftSeason2,
		date: "2019-02-18",
		missing: true,
		size: null
	},
	{
		name: "Chromocraft Season 3",
		url: null,
		image: chromocraftSeason3,
		date: "2019-04-28",
		missing: true,
		size: null
	},
	{
		name: "Earth 1:4000 SMP",
		url: "https://archive.org/details/earth-1-4000-smp",
		image: earth14000Smp,
		date: "2020-08-06",
		size: "855.9 MB"
	},
	{
		name: "Chromocraft Season 4",
		url: "https://archive.org/details/chromocraft-season-4",
		image: chromocraftSeason4,
		date: "2020-11-30",
		size: "958.6 MB"
	},
	{
		name: "CitySMP",
		url: "https://archive.org/details/city-smp",
		image: citySmp,
		date: "2021-01-14",
		size: "1.0 GB"
	},
	{
		name: "1.17 SMP",
		url: "https://archive.org/details/1.17-smp",
		image: one17Smp,
		date: "2021-06-15",
		size: "1.3 GB"
	},
	{
		name: "1.18 Snapshot SMP (21w40a)",
		url: "https://archive.org/details/1.18-snapshot-smp",
		image: one18SnapshotSmp,
		date: "2021-10-10",
		size: "370.4 MB"
	},
	{
		name: "mc.dsns.dev",
		subtitle: "Part 1",
		url: "https://archive.org/details/mc.dsns.dev-part-1",
		image: mcDsnsDevPart1,
		date: "2023-06-07",
		size: "4.0 GB"
	},
	{
		name: "mc.dsns.dev",
		subtitle: "Part 2",
		url: "https://archive.org/details/mc.dsns.dev-part-2",
		image: mcDsnsDevPart2,
		date: "2024-06-11",
		size: "2.6 GB"
	},
	{
		name: "Delicious SMP",
		url: "https://archive.org/details/delicious-smp",
		image: deliciousSmp,
		date: "2025-04-08",
		size: "994.2 MB"
	},
	{
		name: "A New Beginning SMP",
		url: "https://archive.org/details/a-new-beginning-smp",
		image: aNewBeginningSmp,
		date: "2025-12-07",
		size: "419.8 MB"
	}
];

const timestamps = smps.map(s => new Date(s.date).getTime());
const gaps = timestamps.slice(1).map((t, i) => t - timestamps[i]);
const maxGap = Math.max(...gaps);
const minRem = 3;
const maxRem = 14;
const margins = gaps.map(g => minRem + (g / maxGap) * (maxRem - minRem));
margins.push(0);
---

<Layout title="Minecraft SMP Timeline/Archive" description="An timeline of all of the SMPs I've hosted.">
	<div class="mx-auto flex max-w-4xl flex-col gap-6 px-4 md:px-8">
		<div class="text-center">
			<h1 class="text-4xl font-extrabold text-gray-900">SMP Timeline/Archive</h1>
			<p class="mx-auto mt-3 max-w-md text-sm text-gray-500">
				Download the <code class="rounded bg-viola-200 px-1.5 py-0.5 font-mono text-xs text-viola-700">.zip</code> and drag it into
				<a href="https://prismlauncher.org/" target="_blank" rel="noopener noreferrer">Prism Launcher</a> to play.
			</p>
		</div>

		<div class="relative pb-8">
			<div class="absolute left-5 top-0 h-full w-0.5 bg-viola-300 md:left-1/2 md:-translate-x-px" aria-hidden="true"></div>

			{
			smps.map((smp, i) => {
				const isLeft = i % 2 === 0;
				return (
					<div class:list={["timeline-entry group relative flex items-start", "pl-16 md:pl-0", isLeft ? "md:flex-row-reverse" : "md:flex-row"]} style={`margin-bottom: ${margins[i]}rem`}>
							<div class="absolute left-5 top-5 z-10 flex -translate-x-1/2 items-center justify-center md:left-1/2">
								<span class="h-4 w-4 rounded-full border-[3px] border-viola-400 bg-viola-50 shadow transition-colors duration-300 group-hover:border-viola-600 group-hover:bg-viola-200" />
							</div>

							<div class:list={["hidden w-1/2 items-start pt-4 md:flex", isLeft ? "justify-start pl-14" : "justify-end pr-14"]}>
								<time class="font-mono text-sm font-semibold text-viola-500">
									{smp.date.length === 4 ? smp.date : new Date(smp.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
								</time>
							</div>

							<div class:list={["w-full md:w-1/2", isLeft ? "md:pr-14" : "md:pl-14"]}>
								<a
									href={smp.url}
									target="_blank"
									rel="noopener noreferrer"
									class="block overflow-hidden rounded-xl bg-viola-100 shadow-lg transition-all duration-300 hover:scale-[1.02] hover:shadow-xl"
								>
									<div class="relative aspect-video w-full overflow-hidden bg-viola-200">
										{smp.image ? (
											<Image src={smp.image} alt={smp.name} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
										) : (
											<div class="flex h-full w-full items-center justify-center text-viola-400">
												<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
													<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
													<polyline points="3.27 6.96 12 12.01 20.73 6.96" />
													<line x1="12" y1="22.08" x2="12" y2="12" />
												</svg>
											</div>
										)}
									</div>

									<div class="p-4">
										<time class="mb-1 block font-mono text-xs font-semibold text-viola-500 md:hidden">
											{smp.date.length === 4 ? smp.date : new Date(smp.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
										</time>

										<p class="text-lg font-bold text-gray-900">{smp.name}</p>
										{smp.subtitle && <span class="text-xs font-medium uppercase tracking-wide text-viola-600">{smp.subtitle}</span>}
										{smp.missing && <span class="text-xs font-medium uppercase tracking-wide text-yellow-600">No World Available</span>}
										<div class="mt-1 flex items-center gap-2 font-mono text-xs text-gray-400">{smp.size && <span>{smp.size}</span>}</div>

										{!smp.missing && (
										<div class="mt-3 flex items-center gap-1 font-mono text-xs uppercase tracking-wide text-viola-500 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
											<span>View Archive</span>
											<span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
										</div>
										)}
									</div>
								</a>
							</div>
						</div>
					);
				})
			}

			<div class="absolute bottom-0 left-5 z-10 flex -translate-x-1/2 items-center justify-center md:left-1/2">
				<span class="h-3 w-3 rounded-full bg-viola-400"></span>
			</div>
		</div>
	</div>

	<script>
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.15 }
		);

		function observe() {
			document.querySelectorAll(".timeline-entry").forEach((el) => observer.observe(el));
		}

		observe();
		document.addEventListener("astro:after-swap", observe);
	</script>

	<style>
		.timeline-entry {
			opacity: 0;
			transform: translateY(2rem);
			transition:
				opacity 0.6s ease,
				transform 0.6s ease;
		}
		.timeline-entry.is-visible {
			opacity: 1;
			transform: translateY(0);
		}
	</style>
</Layout>
